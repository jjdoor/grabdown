{
  "manifest_version": 3,
  "name": "Grabdown — Selection to Markdown",
  "version": "0.1.0",
  "description": "Select anything on a page and copy it as clean Markdown. Zero data collection, no account, minimal permissions.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "activeTab", "scripting", "clipboardWrite"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "action": {
    "default_title": "Grabdown — copy as Markdown",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "copy-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Copy current selection as Markdown"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "grabdown@jjdoor.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
